class AverageApp {

    // Method with throws clause
    public static double average(String[] values) 
            throws NullPointerException, NumberFormatException {

        double sum = 0;

        for (int i = 0; i < values.length; i++) {

            // Check for null
            if (values[i] == null) {
                throw new NullPointerException("Null value found at index " + i);
            }

            // Convert to double
            double num = Double.parseDouble(values[i]);
            sum += num;
        }

        return sum / values.length;
    }

    public static void main(String[] args) {

        // Test cases
        String[] validData = {"10", "20", "30"};
        String[] invalidData = {"10", "abc", "30"};
        String[] nullData = {"10", null, "30"};

        try {
            System.out.println("Valid Data Average: " + average(validData));
        } 
        catch (Exception e) {
            System.out.println("Error in validData: " + e);
        }

        try {
            System.out.println("Invalid Data Average: " + average(invalidData));
        } 
        catch (NumberFormatException e) {
            System.out.println("Number Format Error: " + e.getMessage());
        } 
        catch (Exception e) {
            System.out.println("Error: " + e);
        }

        try {
            System.out.println("Null Data Average: " + average(nullData));
        } 
        catch (NullPointerException e) {
            System.out.println("Null Error: " + e.getMessage());
        } 
        catch (Exception e) {
            System.out.println("Error: " + e);
        } 
        finally {
            System.out.println("Program execution completed");
        }
    }
}
